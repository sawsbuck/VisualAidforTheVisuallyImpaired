{
  "manifest_version": 3,
  "name": "AI Accessibility Assistant",
  "version": "1.0.0",
  "description": "Voice-controlled AI web assistant for enhanced accessibility and productivity",
  
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Accessibility Assistant"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "config.js",
        "logger.js",
        "voice.js",
        "ai.js",
        "commands.js",
        "speech-service.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
